@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="main-card">
            <h2 class="section-title text-center d-block">Giriş Paneli</h2>
            <p class="text-muted text-center mb-4">Siber güvenlik testleri için SQL Injection (admin' --) zafiyeti içerir.</p>

            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="form-label">Kullanıcı Adı</label>
                    <input type="text" name="username" class="form-control" placeholder="admin" required />
                </div>
                <div class="mb-4">
                    <label class="form-label">Şifre</label>
                    <input type="password" name="password" class="form-control" placeholder="P@ssw0rd123!" required />
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <button type="submit" class="btn btn-soft w-100 btn-lg">Sisteme Giriş Yap</button>
            </form>
        </div>
    </div>
</div>
