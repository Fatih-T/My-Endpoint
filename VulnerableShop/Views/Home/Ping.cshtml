@{
    ViewData["Title"] = "Sistem Teşhis";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="main-card">
            <h2 class="section-title">Sistem Teşhis & Ping Modülü</h2>
            <p class="text-muted mb-4">Aşağıdaki form üzerinden belirttiğiniz host adresine ICMP ping isteği gönderebilirsiniz. (Command Injection - RCE Testi İçin Uygundur)</p>

            <form method="get" class="row g-3 mb-4">
                <div class="col-md-9">
                    <label for="ip" class="form-label text-muted">IP veya Host Adresi</label>
                    <input type="text" class="form-control form-control-lg" name="ip" id="ip" placeholder="Örn: 127.0.0.1, 8.8.8.8" />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-soft w-100 btn-lg">Ping At</button>
                </div>
            </form>

            @if (ViewBag.PingResult != null)
            {
                <div class="mt-4">
                    <h5 class="mb-3 text-secondary"><span class="badge bg-soft-primary" style="background-color: #a29bfe; color: white;">Ping Sonucu:</span></h5>
                    <div style="position: relative;">
                        <pre style="border: 1px solid #dfe6e9; box-shadow: inset 0 2px 5px rgba(0,0,0,0.1); border-radius: 8px;">@ViewBag.PingResult</pre>
                        <span style="position: absolute; right: 10px; top: 10px; font-size: 0.8rem; color: #fab1a0;">[Output Log]</span>
                    </div>
                </div>
            }

            <div class="alert alert-warning mt-5" style="background-color: #fff9db; border: 1px solid #ffe066; color: #856404; border-radius: 10px;">
                <div class="d-flex align-items-center">
                    <div style="font-size: 1.5rem; margin-right: 1rem;">🛡️</div>
                    <div>
                        <strong>Analiz Notu:</strong> Bu modül üzerinden komut enjeksiyonu yapıldığında, Carbon Black <code>w3wp.exe</code> süreci altından başlatılan <code>cmd.exe</code> veya <code>ping.exe</code> işlemlerini şüpheli olarak raporlayacaktır.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
