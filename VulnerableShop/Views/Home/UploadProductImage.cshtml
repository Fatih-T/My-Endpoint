@{
    ViewData["Title"] = "Ürün Resmi Yükle";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="main-card">
            <h2 class="section-title">Ürün Resmi Yükleme</h2>
            <p class="text-muted mb-4">Lütfen ürün resminizi aşağıdaki form üzerinden sisteme yükleyin. (Insecure File Upload Testi İçin Uygundur)</p>

            <form method="post" enctype="multipart/form-data" class="mb-4">
                <div class="mb-4 text-center">
                    <div style="background-color: #f1f2f6; border: 2px dashed #dfe6e9; border-radius: 12px; padding: 2.5rem; transition: border-color 0.3s ease;">
                        <span style="font-size: 3.5rem; display: block; margin-bottom: 1rem;">🖼️</span>
                        <input type="file" name="file" class="form-control" id="file" />
                        <label for="file" class="form-label text-muted mt-2 d-block">Lütfen bir resim dosyası seçin (.jpg, .png...)</label>
                    </div>
                </div>
                <button type="submit" class="btn btn-soft w-100 btn-lg">Resmi Sisteme Yükle</button>
            </form>

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-success d-flex align-items-center" style="background-color: #d4edda; border: 1px solid #c3e6cb; color: #155724; border-radius: 8px;">
                    <span style="font-size: 1.2rem; margin-right: 0.8rem;">✅</span>
                    <div>@ViewBag.Message</div>
                </div>
            }

            <div class="alert alert-danger mt-4" style="background-color: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; border-radius: 10px;">
                <div class="d-flex align-items-center">
                    <div style="font-size: 1.5rem; margin-right: 1rem;">⚠️</div>
                    <div>
                        <strong>Güvenlik Uyarısı:</strong> Bu form üzerinde dosya uzantısı doğrulaması yapılmamıştır. Bu durum Carbon Black'in dosya yazma (File Write) eventlerini nasıl analiz ettiğini test etmek içindir.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
